{% assign repo_url = include.repository | split: '/' %}
{% if site.data.repositories.github_users contains repo_url.first %}
  {% assign show_owner = false %}
{% else %}
  {% assign show_owner = true %}
{% endif %}

<div class="repo p-2">
  <a href="https://github.com/{{ include.repository }}" target="_blank" rel="noopener noreferrer">
    <div class="card hoverable">
      <div class="card-body p-3 d-flex align-items-center">
        <i class="fa-brands fa-github fa-2x mr-3"></i>
        <div>
          {% if show_owner %}
            <div class="text-muted small">{{ repo_url[0] }}</div>
          {% endif %}
          <div class="font-weight-bold">{{ repo_url[1] }}</div>
        </div>
      </div>
    </div>
  </a>
</div>
