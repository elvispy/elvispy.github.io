{% assign repo_url = include.repository | split: '/' %}
{% if site.data.repositories.github_users contains repo_url.first %}
  {% assign show_owner = false %}
{% else %}
  {% assign show_owner = true %}
{% endif %}

<div class="repo p-2 text-center">
  <a href="https://github.com/{{ include.repository }}" target="_blank" rel="noopener noreferrer" style="text-decoration:none;">
    <div class="github-pin-card" data-repo="{{ include.repository }}">
      <div class="gpc-header">
        <svg viewBox="0 0 16 16" width="16" height="16" aria-hidden="true" class="gpc-icon">
          <path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8Z"/>
        </svg>
        <span class="gpc-title">
          {% if show_owner %}<span class="gpc-owner">{{ repo_url[0] }} / </span>{% endif %}{{ repo_url[1] }}
        </span>
      </div>
      <p class="gpc-description"></p>
      <div class="gpc-footer">
        <span class="gpc-lang" style="display:none;">
          <span class="gpc-lang-dot"></span>
          <span class="gpc-lang-name"></span>
        </span>
        <span class="gpc-stars">
          <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/></svg>
          <span class="gpc-stars-count">—</span>
        </span>
        <span class="gpc-forks">
          <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true"><path d="M5 5.372v.878c0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75v-.878a2.25 2.25 0 1 1 1.5 0v.878a2.25 2.25 0 0 1-2.25 2.25h-1.5v2.128a2.251 2.251 0 1 1-1.5 0V8.5h-1.5A2.25 2.25 0 0 1 3.5 6.25v-.878a2.25 2.25 0 1 1 1.5 0ZM5 3.25a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Zm6.75.75a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm-3 8.75a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Z"/></svg>
          <span class="gpc-forks-count">—</span>
        </span>
      </div>
    </div>
  </a>
</div>

{% unless _gh_pin_assets_loaded %}
{% assign _gh_pin_assets_loaded = true %}
<style>
.github-pin-card {
  font-family: 'Segoe UI', Ubuntu, Sans-Serif;
  font-size: 12px;
  background: #fffefe;
  border: 1px solid #e4e2e2;
  border-radius: 4.5px;
  padding: 35px 25px 25px;
  text-align: left;
  width: 100%;
  box-sizing: border-box;
  transition: box-shadow 0.2s ease;
}
.github-pin-card:hover { box-shadow: 0 2px 8px rgba(0,0,0,0.12); }
html[data-theme="dark"] .github-pin-card {
  background: #151515;
  border-color: #444;
}
.gpc-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 12px;
  overflow: hidden;
}
.gpc-icon { fill: #586069; flex-shrink: 0; }
html[data-theme="dark"] .gpc-icon { fill: #79ff97; }
.gpc-title {
  font-size: 18px;
  font-weight: 600;
  color: #2f80ed;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
html[data-theme="dark"] .gpc-title { color: #ffffff; }
.gpc-owner { color: #2f80ed; }
html[data-theme="dark"] .gpc-owner { color: #ffffff; }
.gpc-description {
  font-size: 13px;
  color: #434d58;
  line-height: 1.5;
  margin: 0 0 20px;
  min-height: 2.6em;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
html[data-theme="dark"] .gpc-description { color: #9f9f9f; }
.gpc-footer {
  display: flex;
  align-items: center;
  gap: 25px;
  font-size: 12px;
  color: #586069;
}
html[data-theme="dark"] .gpc-footer { color: #9f9f9f; }
.gpc-lang { display: flex; align-items: center; gap: 6px; }
.gpc-lang-dot { width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0; }
.gpc-stars, .gpc-forks { display: flex; align-items: center; gap: 4px; }
.gpc-stars svg, .gpc-forks svg { fill: #586069; }
html[data-theme="dark"] .gpc-stars svg,
html[data-theme="dark"] .gpc-forks svg { fill: #9f9f9f; }
</style>

<script>
(function () {
  if (window._ghPinLoaded) return;
  window._ghPinLoaded = true;

  var LANG_COLORS = {
    "Julia":"#a270ba","Python":"#3572A5","JavaScript":"#f1e05a",
    "TypeScript":"#3178c6","C++":"#f34b7d","C":"#555555","C#":"#178600",
    "Rust":"#dea584","Go":"#00ADD8","Java":"#b07219","Kotlin":"#A97BFF",
    "Swift":"#F05138","Ruby":"#701516","PHP":"#4F5D95","Scala":"#c22d40",
    "MATLAB":"#e16737","R":"#198CE7","Shell":"#89e051","HTML":"#e34c26",
    "CSS":"#563d7c","Fortran":"#4d41b1","Haskell":"#5e5086",
    "Jupyter Notebook":"#DA5B0B","TeX":"#3D6117","Lua":"#000080",
    "Makefile":"#427819","Dockerfile":"#384d54"
  };

  function fmt(n) { return n >= 1000 ? (n/1000).toFixed(1)+'k' : String(n); }

  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.github-pin-card[data-repo]').forEach(function (card) {
      fetch('https://api.github.com/repos/' + card.getAttribute('data-repo'))
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (d) {
          if (!d) return;
          var desc = card.querySelector('.gpc-description');
          if (desc) desc.textContent = d.description || '';
          var sc = card.querySelector('.gpc-stars-count');
          if (sc) sc.textContent = fmt(d.stargazers_count);
          var fc = card.querySelector('.gpc-forks-count');
          if (fc) fc.textContent = fmt(d.forks_count);
          if (d.language) {
            var lw = card.querySelector('.gpc-lang');
            var ld = card.querySelector('.gpc-lang-dot');
            var ln = card.querySelector('.gpc-lang-name');
            if (lw && ld && ln) {
              ld.style.backgroundColor = LANG_COLORS[d.language] || '#8b949e';
              ln.textContent = d.language;
              lw.style.display = 'flex';
            }
          }
        })
        .catch(function(){});
    });
  });
}());
</script>
{% endunless %}
