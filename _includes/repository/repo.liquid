{% assign repo_url = include.repository | split: '/' %}
{% if site.data.repositories.github_users contains repo_url.first %}
  {% assign show_owner = false %}
{% else %}
  {% assign show_owner = true %}
{% endif %}

<div class="repo p-2">
  <a href="https://github.com/{{ include.repository }}" target="_blank" rel="noopener noreferrer">
    <div class="card hoverable github-repo-card" data-repo="{{ include.repository }}">
      <div class="card-body p-3">
        <div class="d-flex align-items-center mb-1">
          <i class="fa-regular fa-bookmark mr-2 text-muted" style="font-size:0.9em;"></i>
          <span class="font-weight-bold" style="font-size:0.95em;">
            {% if show_owner %}{{ include.repository }}{% else %}{{ repo_url[1] }}{% endif %}
          </span>
        </div>
        <p class="text-muted repo-description mb-2" style="font-size:0.8em;min-height:2.4em;"></p>
        <div class="d-flex align-items-center text-muted" style="font-size:0.8em;">
          <span class="mr-3">
            <i class="fa-regular fa-star mr-1"></i><span class="repo-stars">—</span>
          </span>
          <span>
            <i class="fa-solid fa-code-fork mr-1"></i><span class="repo-forks">—</span>
          </span>
          <span class="ml-auto repo-language"></span>
        </div>
      </div>
    </div>
  </a>
</div>

{% unless _gh_repo_script_loaded %}
{% assign _gh_repo_script_loaded = true %}
<script>
(function () {
  if (window._ghRepoCardsLoaded) return;
  window._ghRepoCardsLoaded = true;

  function fmt(n) { return n >= 1000 ? (n / 1000).toFixed(1) + 'k' : String(n); }

  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.github-repo-card[data-repo]').forEach(function (card) {
      var repo = card.getAttribute('data-repo');
      fetch('https://api.github.com/repos/' + repo)
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (data) {
          if (!data) return;
          var desc = card.querySelector('.repo-description');
          if (desc) desc.textContent = data.description || '';
          var stars = card.querySelector('.repo-stars');
          if (stars) stars.textContent = fmt(data.stargazers_count);
          var forks = card.querySelector('.repo-forks');
          if (forks) forks.textContent = fmt(data.forks_count);
          var lang = card.querySelector('.repo-language');
          if (lang && data.language) lang.textContent = data.language;
        })
        .catch(function () {});
    });
  });
}());
</script>
{% endunless %}
