<div class="repo p-2">
  <a href="https://github.com/{{ include.username }}" target="_blank" rel="noopener noreferrer">
    <div class="card hoverable">
      <div class="card-body p-3 d-flex align-items-center">
        <img
          src="https://github.com/{{ include.username }}.png?size=80"
          alt="{{ include.username }}"
          width="40" height="40"
          class="rounded-circle mr-3"
          style="object-fit: cover;"
        />
        <div class="font-weight-bold">{{ include.username }}</div>
      </div>
    </div>
  </a>
</div>
